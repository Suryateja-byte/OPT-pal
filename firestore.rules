rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function changedOnly(allowedKeys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(allowedKeys);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'uid',
          'email',
          'travelAdvisorEnabled',
          'i983AssistantEnabled',
          'visaPathwayPlannerEnabled',
          'scenarioSimulatorEnabled',
          'peerDataEnabled',
          'optType',
          'optStartDate',
          'unemploymentTrackingStartDate',
          'optEndDate',
          'sevisId',
          'schoolName',
          'cipCode',
          'majorName',
          'firstUsStudentTaxYear',
          'onboardingSource',
          'onboardingDocumentIds',
          'onboardingConfirmedAt'
        ]);
      allow delete: if false;
    }

    match /users/{userId}/documents/{documentId} {
      allow read: if isOwner(userId);
      allow create: if false;
      allow update: if isOwner(userId) &&
        changedOnly(['userTag']);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/employment/{employmentId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasOnly([
          'employerName',
          'startDate',
          'endDate',
          'jobTitle',
          'hoursPerWeek'
        ]);
      allow update: if isOwner(userId) &&
        changedOnly([
          'employerName',
          'startDate',
          'endDate',
          'jobTitle',
          'hoursPerWeek'
        ]);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/reporting/{obligationId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasOnly([
          'eventType',
          'description',
          'eventDate',
          'dueDate',
          'isCompleted',
          'createdBy',
          'wizardId',
          'relatedEmploymentId',
          'actionType',
          'sourceEventType'
        ]);
      allow update: if isOwner(userId) &&
        changedOnly([
          'eventType',
          'description',
          'eventDate',
          'dueDate',
          'isCompleted',
          'createdBy'
        ]);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/reportingWizards/{wizardId} {
      allow read: if isOwner(userId);
      allow create: if false;
      allow update: if isOwner(userId) &&
        changedOnly([
          'status',
          'userInputs',
          'editedDraft',
          'copiedAt'
        ]);
      allow delete: if false;
    }

    match /users/{userId}/i983Drafts/{draftId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasOnly([
          'workflowType',
          'status',
          'linkedEmploymentId',
          'linkedObligationId',
          'revisionOfDraftId',
          'templateVersion',
          'policyVersion',
          'selectedDocumentIds',
          'latestExportDocumentId',
          'signedDocumentId',
          'studentSection',
          'employerSection',
          'trainingPlanSection',
          'evaluationSection',
          'generatedNarrative',
          'createdAt',
          'updatedAt',
          'exportedAt',
          'signedLinkedAt'
        ]);
      allow update: if isOwner(userId) &&
        changedOnly([
          'workflowType',
          'status',
          'linkedEmploymentId',
          'linkedObligationId',
          'revisionOfDraftId',
          'templateVersion',
          'policyVersion',
          'selectedDocumentIds',
          'latestExportDocumentId',
          'signedDocumentId',
          'studentSection',
          'employerSection',
          'trainingPlanSection',
          'evaluationSection',
          'generatedNarrative',
          'updatedAt',
          'exportedAt',
          'signedLinkedAt'
        ]);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/visaPathwayPlanner/{docId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasOnly([
          'desiredContinuityDate',
          'employerType',
          'employerUsesEVerify',
          'employerWillSponsorH1b',
          'h1bRegistrationStatus',
          'degreeLevel',
          'hasPriorUsStemDegree',
          'roleDirectlyRelatedToDegree',
          'hasPetitioningEmployerOrAgent',
          'o1EvidenceSignals',
          'preferredPathwayId',
          'hasStatusViolation',
          'hasArrestHistory',
          'hasUnauthorizedEmployment',
          'hasRfeOrNoid',
          'updatedAt'
        ]);
      allow update: if isOwner(userId) &&
        changedOnly([
          'desiredContinuityDate',
          'employerType',
          'employerUsesEVerify',
          'employerWillSponsorH1b',
          'h1bRegistrationStatus',
          'degreeLevel',
          'hasPriorUsStemDegree',
          'roleDirectlyRelatedToDegree',
          'hasPetitioningEmployerOrAgent',
          'o1EvidenceSignals',
          'preferredPathwayId',
          'hasStatusViolation',
          'hasArrestHistory',
          'hasUnauthorizedEmployment',
          'hasRfeOrNoid',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /users/{userId}/h1bDashboard/{docId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && (
        (docId == 'profile' && request.resource.data.keys().hasOnly([
          'employerName',
          'employerCity',
          'employerState',
          'feinLastFour',
          'employerType',
          'selfReportedSponsorIntent',
          'roleMatchesSpecialtyOccupation',
          'updatedAt'
        ])) ||
        (docId == 'employerVerification' && request.resource.data.keys().hasOnly([
          'eVerifyStatus',
          'eVerifyLookedUpAt',
          'eVerifySourceUrl',
          'eVerifyUserConfirmed',
          'employerHistory',
          'updatedAt'
        ])) ||
        (docId == 'timelineState' && request.resource.data.keys().hasOnly([
          'workflowStage',
          'selectedRegistration',
          'filedPetition',
          'requestedChangeOfStatus',
          'requestedConsularProcessing',
          'selectedAt',
          'petitionFiledAt',
          'receiptReceivedAt',
          'receiptNumber',
          'updatedAt'
        ])) ||
        (docId == 'caseTracking' && request.resource.data.keys().hasOnly([
          'linkedCaseId',
          'linkedReceiptNumber',
          'updatedAt'
        ])) ||
        (docId == 'evidence' && request.resource.data.keys().hasOnly([
          'hasEmployerLetter',
          'hasWageInfo',
          'hasDegreeMatchEvidence',
          'hasRegistrationConfirmation',
          'hasReceiptNotice',
          'hasCapExemptSupport',
          'capGapTravelPlanned',
          'hasRfeOrNoid',
          'updatedAt'
        ]))
      );
      allow update: if isOwner(userId) && (
        (docId == 'profile' && changedOnly([
          'employerName',
          'employerCity',
          'employerState',
          'feinLastFour',
          'employerType',
          'selfReportedSponsorIntent',
          'roleMatchesSpecialtyOccupation',
          'updatedAt'
        ])) ||
        (docId == 'employerVerification' && changedOnly([
          'eVerifyStatus',
          'eVerifyLookedUpAt',
          'eVerifySourceUrl',
          'eVerifyUserConfirmed',
          'employerHistory',
          'updatedAt'
        ])) ||
        (docId == 'timelineState' && changedOnly([
          'workflowStage',
          'selectedRegistration',
          'filedPetition',
          'requestedChangeOfStatus',
          'requestedConsularProcessing',
          'selectedAt',
          'petitionFiledAt',
          'receiptReceivedAt',
          'receiptNumber',
          'updatedAt'
        ])) ||
        (docId == 'caseTracking' && changedOnly([
          'linkedCaseId',
          'linkedReceiptNumber',
          'updatedAt'
        ])) ||
        (docId == 'evidence' && changedOnly([
          'hasEmployerLetter',
          'hasWageInfo',
          'hasDegreeMatchEvidence',
          'hasRegistrationConfirmation',
          'hasReceiptNotice',
          'hasCapExemptSupport',
          'capGapTravelPlanned',
          'hasRfeOrNoid',
          'updatedAt'
        ]))
      );
      allow delete: if false;
    }

    match /users/{userId}/peerData/{docId} {
      allow read: if isOwner(userId) && docId == 'settings';
      allow create: if isOwner(userId) &&
        docId == 'settings' &&
        request.resource.data.keys().hasOnly([
          'contributionEnabled',
          'contributionVersion',
          'previewedAt',
          'withdrawnAt',
          'updatedAt'
        ]);
      allow update: if isOwner(userId) &&
        docId == 'settings' &&
        changedOnly([
          'contributionEnabled',
          'contributionVersion',
          'previewedAt',
          'withdrawnAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /users/{userId}/scenarioSimulatorDrafts/{scenarioId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasOnly([
          'templateId',
          'name',
          'assumptions',
          'createdAt',
          'updatedAt',
          'lastRunAt',
          'baselineFingerprint',
          'lastOutcome',
          'archivedAt',
          'pinned'
        ]);
      allow update: if isOwner(userId) &&
        changedOnly([
          'templateId',
          'name',
          'assumptions',
          'createdAt',
          'updatedAt',
          'lastRunAt',
          'baselineFingerprint',
          'lastOutcome',
          'archivedAt',
          'pinned'
        ]);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/uscisCases/{caseId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/policyAlertState/{alertId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasOnly([
          'alertId',
          'openedAt',
          'lastSeenAt'
        ]);
      allow update: if isOwner(userId) &&
        changedOnly([
          'alertId',
          'openedAt',
          'lastSeenAt'
        ]);
      allow delete: if false;
    }

    match /users/{userId}/ficaRefundCases/{caseId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasOnly([
          'w2DocumentId',
          'taxYear',
          'employerName',
          'employerOutcome',
          'status',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if isOwner(userId) &&
        changedOnly([
          'userInputs',
          'employerOutcome',
          'status',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /users/{userId}/notificationDevices/{installationId} {
      allow read, create, update, delete: if false;
    }

    match /policyAlerts/{alertId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    match /peerDataFacts/{factId} {
      allow read, create, update, delete: if false;
    }

    match /peerDataSnapshots/{snapshotId} {
      allow read, create, update, delete: if false;

      match /{document=**} {
        allow read, create, update, delete: if false;
      }
    }

    match /policyAlertCandidates/{candidateId} {
      allow read, create, update, delete: if false;
    }

    match /scan_results/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
